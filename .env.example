# Jira OAuth Configuration
# Register app at: https://developer.atlassian.com/console/apps
# Scopes: read:jira-work, write:jira-work, read:jira-user, offline_access
JIRA_CLIENT_ID="MY_JIRA_CLIENT_ID"
JIRA_CLIENT_SECRET="MY_JIRA_CLIENT_SECRET"
# For development:
JIRA_REDIRECT_URI="http://localhost:3000/api/auth/jira/callback"
# For production (replace with your Vercel domain):
# JIRA_REDIRECT_URI="https://your-app.vercel.app/api/auth/jira/callback"

# Environment
NODE_ENV="development"
